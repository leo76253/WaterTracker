@page "/dashboard"
@attribute [Authorize]
@using WaterTracker.Services
@inject WaterIntakeService WaterIntakeService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

@if (loading)
{
    @* TODO: spinner *@
    <p>Loading...</p>
}
else
{
    <div>
        <table class="table">
            <thead>
                <tr>
                    <th class="col-4">Date</th>
                    <th class="col-3">Amount (L)</th>
                    <th class="col-5">
                        <div class="d-flex column justify-content-between align-items-end">
                            <span>Actions</span>
                            <div>

                                <button class="btn btn-success btn-sm" @onclick="AddIntake">
                                    <span class="bi bi-plus-lg" aria-hidden="true"></span>
                                    Add Intake
                                </button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshIntakes">
                                    <span class="bi bi-arrow-clockwise" aria-label="refresh"></span>
                                </button>
                            </div>
                        </div>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var intake in waterIntakes)
                {
                    <tr>
                        <td class="col-4">@intake.Date.ToString("g")</td>
                        <td class="col-3">@intake.Amount.ToString("F1") L</td>
                        <td class="col-5">
                            <button class="btn btn-primary btn-sm" @onclick="() => EditIntake(intake.Id)">
                                <span class="bi bi-pencil" aria-hidden="true"></span>
                                Edit
                            </button>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteIntake(intake.Id)">
                                <span class="bi bi-trash3" aria-hidden="true"></span>
                                Delete
                            </button>
                        </td>
                    </tr>
                }
                @if (waterIntakes.Count == 0)
                {
                    <tr>
                        <td colspan="3" class="text-primary text-center border-0">No Water Intakes to show.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<WaterIntakeResponse> waterIntakes = [];
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadIntakes();
        loading = false;
    }

    private async Task LoadIntakes()
    {
        try
        {
            waterIntakes = await WaterIntakeService.GetAllAsync();
        }
        catch
        {
            // TODO: Popup error
            Console.WriteLine("Error fetching water intake");
            await JS.InvokeVoidAsync("alert", "Error occurred when fetching water.");
        }
    }

    private async Task DeleteIntake(Guid id)
    {
        // Note: Yes in a normal production I would make a generic popup for confirmations and errors but this will do for now given time constraint
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this intake?");
        if (!confirmed) return;

        bool success = await WaterIntakeService.DeleteAsync(id);
        if (success)
        {
            waterIntakes.RemoveAll(i => i.Id == id);
        }
    }

    private async Task RefreshIntakes()
    {
        loading = true;
        await LoadIntakes();
        loading = false;
    }

    private void AddIntake()
    {
        NavigationManager.NavigateTo("/wi");
    }

    private void EditIntake(Guid id)
    {
        NavigationManager.NavigateTo($"/wi/{id:D}");
    }
}

