@page "/register"
@using System.Net.Http.Json
@using System.Text.RegularExpressions
@using WaterTracker.Services

@inject HttpClient Http
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Register</PageTitle>

<div class="d-flex align-items-center justify-content-center min-vh-100">
    <div class="bg-light border rounded-2 p-3 w-100" style="max-width: 640px;">
        <EditForm Model="registerFormModel" OnSubmit="HandleRegistration">
            <h1>Register</h1>

            <div class="mb-3">
                <label for="forename" class="form-label">Forename</label>
                <InputText id="forename" class="form-control" disabled="@isSubmitting" @bind-Value="registerFormModel.Forename" type="text"
                           required />
            </div>
            <div class="mb-3">
                <label for="surname" class="form-label">Surname</label>
                <InputText id="surname" class="form-control" disabled="@isSubmitting" @bind-Value="registerFormModel.Surname" type="text" required />
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <InputText id="email" class="form-control" disabled="@isSubmitting" @bind-Value="registerFormModel.Email" type="email" required />
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <InputText id="password" class="form-control" disabled="@isSubmitting" @bind-Value="registerFormModel.Password" type="password"
                           required />
            </div>
            <div class="mb-4">
                <label for="confirmPassword" class="form-label">Confirm Password</label>
                <InputText id="confirmPassword" class="form-control" disabled="@isSubmitting" @bind-Value="registerFormModel.ConfirmPassword"
                           type="password" required />
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger mb-4" role="alert">@error</div>
            }

            @if (@isRegisterSuccess)
            {
                <div class="alert alert-success mb-4" role="alert">Registration successful! Getting you logged in...</div>
            }

            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Creating Account...</span>
                    }
                    else
                    {
                        <span>Create Account</span>
                    }
                </button>
                <a href="login" class="btn btn-link">Already have an account? Log in</a>
            </div>
        </EditForm>
    </div>
</div>


@code {
    private RegisterFormModel registerFormModel = new RegisterFormModel();
    private bool isSubmitting = false;
    private string? error;
    private bool isRegisterSuccess;
    private static readonly Regex PasswordRegex =
        new Regex(pattern: @"^(?=.*[A-Z])(?=.*\d).{8,}$");

    private async Task HandleRegistration()
    {
        isSubmitting = true;
        error = null;

        if (!Validate())
        {
            isSubmitting = false;
            return;
        }

        var response = await Http.PostAsJsonAsync("/api/auth/register", registerFormModel);
        var content = await response.Content.ReadAsStringAsync();
        if (response.IsSuccessStatusCode)
        {
            isRegisterSuccess = true;
            await Task.Delay(2000);

            bool loginSuccess = await AuthService.LoginAsync(registerFormModel.Email, registerFormModel.Password);


            if (loginSuccess)
            {
                Console.WriteLine("Login successful");
                Navigation.NavigateTo("/dashboard");
            }
            else
            {
                Console.WriteLine("Login failed");
                error = "Invalid email or password";
            }
        }
        else
        {
            Console.WriteLine($"Registration failed: {content}");
            error = "Registration failed, please try again";
        }
        isSubmitting = false;
    }

    private bool Validate()
    {
        if (registerFormModel.Password != registerFormModel.ConfirmPassword)
        {
            error = "Passwords do not match";
            return false;
        }

        if (!PasswordRegex.IsMatch(registerFormModel.Password))
        {
            error = "Password must be at least 8 characters long and include one uppercase letter and one digit";
            return false;
        }

        return true;
    }

    private class RegisterFormModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
        public string Forename { get; set; } = "";
        public string Surname { get; set; } = "";
    }

}
